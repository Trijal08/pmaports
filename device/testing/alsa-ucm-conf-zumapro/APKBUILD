maintainer="Trijal Saha <trijalsaha2012@gmail.com>"
pkgname=alsa-ucm-conf-zumapro
pkgver=1
pkgrel=0
pkgdesc="ALSA UCM configuration for Google Zuma(Pro) devices"
url="https://github.com/Trijal08/alsa-ucm-conf"
arch="aarch64"
license="BSD-3-Clause"
provides="alsa-ucm-conf"
provider_priority=1
_owner="Trijal08"
_repository="alsa-ucm-conf"
_commit="zumapro-google-caimito"
source="
	$pkgname-$_commit.tar.gz::https://github.com/$_owner/$_repository/archive/$_commit.tar.gz
"
options="!check"
builddir="$srcdir/$_repository-$_commit"

package() {
	# install audio config files
	mkdir -p "$pkgdir"/usr/share/alsa
	cp -r "$builddir"/ucm2 \
		"$pkgdir"/usr/share/alsa/
}

sha512sums="
"
