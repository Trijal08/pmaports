modem() {
	pkgdesc="Google Pixel 9 Pro XL S5400 Modem and GNSS firmware"

	# Modem Partition Mounting Script
	install -Dm755 "$srcdir"/initramfs_setup_modemfw.sh \
		-t "$subpkgdir/usr/share/mkinitfs/hooks-cleanup/"

	# Carrier config
	install -d "$subpkgdir/lib/firmware/google/s5400/carrierconfig/"
	rsync -a --chmod=D755,F644 "$builddir"/proprietary/vendor/firmware/carrierconfig/ "$subpkgdir/lib/firmware/google/s5400/carrierconfig/"

	# UE Cap config
	install -d "$subpkgdir/lib/firmware/google/s5400/uecapconfig/"
	rsync -a --chmod=D755,F644 "$builddir"/proprietary/vendor/firmware/uecapconfig/ "$subpkgdir/lib/firmware/google/s5400/uecapconfig/"

	# Main Firmware Blob
	install -Dm644 "$builddir"/proprietary/vendor/firmware/kepler.bin \
		"$subpkgdir/lib/firmware/google/s5400/kepler.bin"
}

aoc() {
	pkgdesc="Google Pixel 9 Pro XL AoC (Always-on-Compute) firmware"

	# Main Firmware Blob
	install -Dm644 "$builddir"/proprietary/vendor/firmware/aoc.bin \
		"$subpkgdir/lib/firmware/google/aoc.bin"
}
