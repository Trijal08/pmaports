maintainer="Trijal Saha <trijalsaha2012@gmail.com>"
pkgname=firmware-google-komodo
pkgver=20260627
pkgrel=1
pkgdesc="Firmware for Google Pixel 9 Pro XL"
subpackages="
	$pkgname-brcm_a0
	$pkgname-brcm_b0
	$pkgname-brcm_b1
	$pkgname-modem
	$pkgname-aoc
	"
arch="aarch64"
_carch="arm64"
_flavor="postmarketos-zumapro"
url="https://kernel.org"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
makedepends="
	rsync
"

# Source
_owner="TheMuppets"
_repository="proprietary_vendor_google_komodo"
_commit="lineage-24.0"
source="
	$pkgname-$_commit.tar.gz::https://github.com/$_owner/$_repository/archive/$_commit.tar.gz
	initramfs_setup_modemfw.sh
"
builddir="$srcdir/$_repository-$_commit"

package() {
	# parent package is empty
	mkdir -p "$pkgdir"
}

brcm_a0() {
	pkgdesc="Google Pixel 9 Pro XL Broadcom BCM4390A0 firmware"

	# Main Firmware Blob
	install -Dm644 "$builddir"/proprietary/vendor/firmware/fw_bcmdhd.bin_4390_a0 \
		"$subpkgdir/lib/firmware/brcm/brcmfmac4390a0-pcie.bin"

	# NVRAM Blob (plain text)
	install -Dm644 "$builddir"/proprietary/vendor/firmware/bcmdhd.cal_4390_a0 \
		"$subpkgdir/lib/firmware/brcm/brcmfmac4390a0-pcie.txt"

	# CLM Binary Blob
	install -Dm644 "$builddir"/proprietary/vendor/firmware/bcmdhd_clm.blob_4390_a0 \
		"$subpkgdir/lib/firmware/brcm/brcmfmac4390a0-pcie.clm_blob"

	# TXCAP Blob
	install -Dm644 "$builddir"/proprietary/vendor/firmware/bcmdhd_txcap.blob_4390_a0 \
		"$subpkgdir/lib/firmware/brcm/brcmfmac4390a0-pcie.txcap_blob"

	# Bluetooth HCD Blob
	# install -Dm644 "$builddir"/proprietary/vendor/firmware/brcm/BCM_200.hcd \
	# 	"$subpkgdir/lib/firmware/brcm/BCM4390A0.hcd"
	install -Dm644 "$builddir"/proprietary/vendor/firmware/brcm/BCM_200.hcd \
		"$subpkgdir/lib/firmware/brcm/BCM.hcd"
}

